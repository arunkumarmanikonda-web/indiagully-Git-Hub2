        '<td style="font-size:.7rem">' + p.owner + '</td>' +
        '<td><span style="color:' + sc + ';font-size:.7rem;font-weight:700">' + p.status + '</span></td>' +
        '<td style="color:' + od + ';font-size:.7rem">' + p.review_date + '</td>' +
