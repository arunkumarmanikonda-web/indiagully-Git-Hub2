        '<td style="font-size:.7rem">₹' + dp.amount_inr.toLocaleString() + '</td>' +
        '<td style="font-size:.68rem;color:#6b7280">' + dp.reason + '</td>' +
        '<td><span style="color:' + sc + ';font-size:.7rem;font-weight:700">' + dp.status + '</span></td>' +
