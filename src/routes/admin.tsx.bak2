        '<p><b>User Verification:</b> ' + (s.user_verification||'—') + ' &nbsp;|&nbsp; <b>Algorithms:</b> ' + (s.supported_algorithms||[]).join(', ') + '</p>' +
        '<table style="width:100%;border-collapse:collapse;margin-top:.5rem;font-size:.8rem">' +
