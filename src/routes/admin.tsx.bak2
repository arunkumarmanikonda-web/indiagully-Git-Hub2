      '<p style="font-size:.73rem;margin-top:.5rem;color:#1e3a5f"><b>PAM:</b> ' + (pam.super_admin_mfa||'—') + ' &nbsp;|&nbsp; Next review: ' + (pam.quarterly_review_due||'—') + '</p>');
